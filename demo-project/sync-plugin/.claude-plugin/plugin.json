{
    "name": "sync-plugin-official",
    "version": "1.0.0",
    "description": "Official Claude Code setup for Synechron team",
    "author": {
        "name": "Synechron Team"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/bash-guard.js"
                    },
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/pretooluse-demo.js"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/eslint-fix.js"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/session-log.js"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "permission_prompt",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/slack-notify.js"
                    }
                ]
            },
            {
                "matcher": "idle_prompt",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node sync-plugin/hooks/slack-notify.js"
                    }
                ]
            }
        ]
    }
}